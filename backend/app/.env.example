# firebase
# -go to https://console.firebase.google.com
# -select the Firebase project to use
# -go to "Settings" > "Service accounts"
# -scroll down and click "Generate new private key"
# -copy the values from the downloaded file and replace the placeholder values
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="your-firebase-client-email"

# google login
# -go to https://console.cloud.google.com/
# -select the same Firebase project used above
# -go to "API & Services"
# -under "OAuth 2.0 Client IDs", select the pencil "Edit OAuth Client" button
# -copy client ID under "Additional information" line
# -scroll down and select "Add secret", then copy the newly created secret
# -copy redirect URI under "Authorized redirect URIs" line
# -replace the placeholder values with the copied values
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="your-google-redirect-url"

# -go to https://console.firebase.google.com
# -go to "Settings" > "General"
# -scroll down to "Your apps" section
# -add a new web app if none exists
# -make a copy of this file and rename it to .env
# -copy the API key from firebaseConfig and replace the placeholder value
FIREBASE_WEB_API_KEY="your-firebase-web-api-key"
FRONTEND_URL="http://localhost:5173"